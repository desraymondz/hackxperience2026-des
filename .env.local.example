# Supabase — Settings > API in your project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
PORTAL_AUTH_SECRET=replace-with-a-long-random-secret

# Submission window (ISO 8601 UTC). Leave either unset to remove that gate.
# SGT = UTC+8 — remember to subtract 8h when writing UTC values.
# Example: hackathon 22 May 09:00 SGT → 23 May 00:00 SGT
# NEXT_PUBLIC_SUBMISSION_OPEN_AT=2026-05-22T01:00:00Z
# NEXT_PUBLIC_SUBMISSION_DEADLINE=2026-05-22T16:00:00Z
